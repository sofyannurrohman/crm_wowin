# SERVER CONFIG
PORT=8080
GIN_MODE=debug # 'debug' or 'release'

# DATABASE CONFIG
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wowin_crm

# DATABASE TARGET (Local execution targetting the docker instance)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wowin_crm?sslmode=disable

# REDIS CONFIG
REDIS_URL=redis://localhost:6379/0

# AUTHENTICATION
JWT_SECRET=super_secret_jwt_key_please_change_this_in_production
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# UPLOADS CONFIG
UPLOADS_DIR=./storage/uploads
